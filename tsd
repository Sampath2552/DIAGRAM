import sys
from common.createSpark import create_spark_session
from common.fileUtil import get_hdfs_base
import common.constants as constants
from common.dateUtil import get_etl_date
from pyspark.sql.functions import col, sum as spark_sum
from common.processRun import get_process_run_id
from common.constants import Process
CIBA_CGL = "110x65x05x001"
TECHNICAL_SUSPENSE_CGL = "12x60x50x50x01"
BATCH_ID_COLUMN = "BATCH_ID"
AMOUNT_COLUMN = "AMOUNT"
TOTAL_AMOUNT = "total_amount"
JOURNAL_NUMBER = "JOURNAL_NUMBER"
CURRENCY = "CURRENCY"
BRANCH_COLUMN = "BRANCH_CODE"
CIBA = "ciba_details_report/ciba_details_report"
SUSPENSE = "technical_suspense_details_report/technical_suspense_details_report"
HDFS_BASE = get_hdfs_base()
CIBA_COLUMNS = ["POST_DATE",JOURNAL_NUMBER,"BRCH","FCY_CODE","BRANCH_CODE",CURRENCY,"CGL",   "DESCRIPTION",   "POST_DATE",   AMOUNT_COLUMN,   "FCY_AMT",   "ACCOUNT",   "SOURCE",   "LCY_AMT",   "FILE_NAME"]
def path_builder(etl_date, report_type):
   input_formatted_date = etl_date.strftime("%Y/%b/%d").upper()
   input_path = (f"{HDFS_BASE}/druid-data-lake/"f"{input_formatted_date}/GLIF/GLIF_TXNS/")
   report_path_date = etl_date.strftime("%Y-%m-%d")
   report_date = etl_date.strftime("%d%m%Y")
   output_path = (f"{HDFS_BASE}/reports/"f"{report_path_date}/{report_type}_{report_date}.xlsx")
   return input_path, output_path
def generate_technical_suspense_report(spark, etl_date, process_run_id):
   input_path, _ = path_builder(etl_date, SUSPENSE)
   print(f"Reading from path : {input_path}")
   report_date = etl_date.strftime("%d%m%Y")
   source_df = (spark.read.format("delta").load(input_path) )
   base_df = (source_df.filter(col("CGL") == TECHNICAL_SUSPENSE_CGL))
   unbalanced_branches_base = (base_df.groupBy(BRANCH_COLUMN, CURRENCY).agg(spark_sum(AMOUNT_COLUMN).alias(AMOUNT_COLUMN)).filter(col(AMOUNT_COLUMN) != 0).select(BRANCH_COLUMN).distinct())
   branches_rows = unbalanced_branches_base.collect()
   unbalanced_branches_list = set()
   for row in branches_rows:
       unbalanced_branches_list.add(getattr(row, BRANCH_COLUMN))
   unbalanced_branches = base_df.filter(col(BRANCH_COLUMN).isin(unbalanced_branches_list))    
   batch_df = unbalanced_branches.filter(col(BATCH_ID_COLUMN).isNotNull())
   journal_df = unbalanced_branches.filter(col(BATCH_ID_COLUMN).isNull())
   unbalanced_batches = (batch_df.groupBy(BATCH_ID_COLUMN, BRANCH_COLUMN, CURRENCY)       .agg(           spark_sum(AMOUNT_COLUMN).alias(TOTAL_AMOUNT)       )       .filter(col(TOTAL_AMOUNT) != 0)       .select(BATCH_ID_COLUMN, BRANCH_COLUMN)       .distinct()   )
   batch_rows = unbalanced_batches.collect()
   batch_ids = set()
   batch_branches = set()
   for row in batch_rows:
       batch_ids.add(getattr(row, BATCH_ID_COLUMN))
       branch = getattr(row, BRANCH_COLUMN)
       if branch is not None:
           batch_branches.add(branch)
   if batch_ids:
       unbalanced_batches_df = (base_df.filter(col(BATCH_ID_COLUMN).isin(batch_ids)))
   else:
       unbalanced_batches_df = spark.createDataFrame([],schema=base_df.schema)
   unbalanced_journals = (journal_df.groupBy(JOURNAL_NUMBER, BRANCH_COLUMN, CURRENCY).agg(spark_sum(AMOUNT_COLUMN).alias(TOTAL_AMOUNT)).filter(col(TOTAL_AMOUNT) != 0).select(JOURNAL_NUMBER, BRANCH_COLUMN).distinct())
   journal_rows = unbalanced_journals.collect()
   journal_ids = set()
   journal_branches = set()
   for row in journal_rows:
       journal_ids.add(getattr(row, JOURNAL_NUMBER))
       branch = getattr(row, BRANCH_COLUMN)
       if branch is not None:
           journal_branches.add(branch)
   if journal_ids:
       unbalanced_journals_df = (base_df.filter(col(JOURNAL_NUMBER).isin(journal_ids)))
   else:
       unbalanced_journals_df = spark.createDataFrame([],schema=base_df.schema)
   unbalanced_batches_df.cache()
   unbalanced_journals_df.cache()
   unique_branches = batch_branches.union(journal_branches)
   print(f"Generating reports for "f"{len(unique_branches)} branches.")
   for branch_code in sorted(unique_branches):
        print(f"Generating report for Branch : {branch_code}")
        branch_batch_df = (            unbalanced_batches_df            .filter(col(BRANCH_COLUMN) == branch_code)        )
        branch_journal_df = (            unbalanced_journals_df            .filter(col(BRANCH_COLUMN) == branch_code)        )
        print(f"Branch Code :: {branch_code} ; Unbalanced Batch Transactions Count for the branch :{branch_batch_df.count()} ; Unbalanced Journal Transactions Count for the branch:{branch_journal_df.count()}") 
        output_file = (f"{HDFS_BASE}/technical_suspense_report/"f"{branch_code}/"f"technical_suspense_report_{report_date}.xlsx")
        print(f"Output File :{output_file}")
        (branch_batch_df.write.format("com.crealytics.spark.excel").option("dataAddress", "'BATCH'!A1").option("header", "true").option("maxRowsInMemory", 5000).mode("overwrite").save(output_file))
        (branch_journal_df.write.format("com.crealytics.spark.excel").option("dataAddress", "'JOURNAL'!A1").option("header", "true").option("maxRowsInMemory", 5000).mode("append").save(output_file))
   base_df.unpersist()
   unbalanced_batches_df.unpersist()
   unbalanced_journals_df.unpersist()
   print("Technical Suspense Reports generated successfully.")
def main(args):
    spark = create_spark_session("Technical_Suspense_Details",HDFS_BASE)
    gateway = spark._jvm
    gateway.org.apache.poi.util.IOUtils.setByteArrayMaxOverride(500 * 1024 * 1024)
    etl_date = get_etl_date(spark)
    process_id = Process.DIFFERENCE_PIPELINE
    spark_date = etl_date.strftime("%Y-%m-%d")
    process_run_id = (args[1] if len(args) > 1 else get_process_run_id(spark,process_id,spark_date))
    print(f"Logging for Process Id : {process_id} "f"and Process Run Id : {process_run_id}")
    generate_technical_suspense_report(spark,etl_date,process_run_id)
if __name__ == "__main__":
    main(sys.argv)
 
 
