    public ReportPath buildReportPath(ReportType reportType, LocalDate reportDate , String branchCode) {
        char type = reportType.getType();
        if (type == Constants.STANDARD) {
            return buildStandardReportPath(reportType, reportDate, branchCode);

        } else if (type == Constants.TB_ASCII_REPORT ||
                type == Constants.ASCII ||
                type == Constants.TB_ASCII) {
            return buildNonStandardReportPath(reportType, reportDate, branchCode,type);
        } else
        {
            throw new IllegalArgumentException("Invalid Report Type");
        }

    }

    private ReportPath buildStandardReportPath(ReportType reportType,
                                               LocalDate reportDate,
                                               String branchCode) {
        String folderDate = reportDate.format(DateTimeFormatter.ISO_LOCAL_DATE);
        String fileDate = reportDate.format(DateTimeFormatter.ofPattern("ddMMyyyy"));
        Path searchDirectory;
        String searchPattern;
        if (branchCode == null || branchCode.isBlank()) {
            searchDirectory = new Path(new Path(reportsBasePath, folderDate),
                    reportType.getFileName());
            searchPattern = String.format("%s_%s",
                    reportType.getFileName(),
                    fileDate);
        } else {
            searchDirectory = new Path(
                    new Path(
                            new Path(reportsBasePath, folderDate),
                            reportType.getFileName()),
                    branchCode);
            searchPattern = String.format("%s_%s_%s",
                    reportType.getFileName(),
                    fileDate,
                    branchCode);
        }
        log.info("Standard Report Search Directory : {}", searchDirectory);
        log.info("Standard Report Search Pattern   : {}", searchPattern);
        return new ReportPath(searchDirectory, searchPattern);
    }


    private  ReportPath buildNonStandardReportPath(ReportType reportType,LocalDate reportDate,String branchCode,char type) {

        String folderDate = reportDate.format(DateTimeFormatter.ISO_LOCAL_DATE);
        String fileDate = reportDate.format(DateTimeFormatter.ofPattern("yyyyMMdd"));
        String secondaryReportBasePath = REPORT_SECONDARY_BASE_PATH_MAP.get(type);
        String reportBranch = (branchCode == null || branchCode.isBlank()) ? WHOLE_BANK_BRANCH_CODE : branchCode;
        if (secondaryReportBasePath == null) throw new IllegalArgumentException("Invalid Report Type");
        String reportFolder = getReportFolder(reportType.getFileName());
        Path searchDirectory = new Path( new Path( new Path( reportsBasePath,folderDate),secondaryReportBasePath),reportFolder);
        String suffix = getSearchPatternSuffix(reportFolder,type);
        String searchPattern = reportBranch+"."+suffix + "."+fileDate;
        log.info("Report Folder :{} - Report Type : {} - Suffix :{} - Report Branch :{}",reportFolder,reportType,suffix,reportBranch);
        log.info("Search Directory :{}",searchDirectory);
        log.info("Search Pattern :{}",searchPattern);
        return new ReportPath(searchDirectory,searchPattern);





    }
    
    private String getSearchPatternSuffix(String reportFolder,char type)
    {
        String suffix;
        if(type == Constants.TB_ASCII || type == Constants.TB_ASCII_REPORT)
        {
            suffix = TB_ASCII_SUFFIX_MAP.get(reportFolder);
        } else if (type == Constants.ASCII) {
            suffix = ASCII_SUFFIX_MAP.get(reportFolder);
        }
        else {
            throw new IllegalArgumentException("Invalid Report ");
        }
        if (suffix == null)  throw  new IllegalArgumentException("Invalid Report ");
        return suffix;
    }



    private String getReportFolder(String fileName)
    {
        if (fileName == null) throw new ResourceNotFoundException("Invalid Report Type");

        if(fileName.contains(NWSA)) return NWSA_REPORT;
        else if (fileName.contains(YSA)) return YSA_REPORT;
        else if (fileName.contains(PNL)) return PNL_REPORT;
        else {
            throw new ResourceNotFoundException("Invalid Report Type");
        }
    }

}
