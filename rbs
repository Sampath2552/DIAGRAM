    private static final String YSA_REPORT="ysa_report";
    private static final String PNL_REPORT="pnl_report";
    private final String NWSA="nwsa";
    private final String YSA="ysa";
    private final String PNL="pnl";
    private final String WHOLE_BANK_BRANCH_CODE = "00000";
    private static final Map<String,String> ASCII_SUFFIX_MAP = Map.of(
            NWSA_REPORT,"*",
            YSA_REPORT,"YSA",
            PNL_REPORT,"PL"
    );
    private static final Map<String,String> TB_ASCII_SUFFIX_MAP = Map.of(
            NWSA_REPORT,"TBNWSA",
            YSA_REPORT,"TBY",
            PNL_REPORT,"TBP"
    );
    private static final Map<Character,String> REPORT_SECONDARY_BASE_PATH_MAP = Map.of(
            Constants.ASCII,"ascii_files",
            Constants.TB_ASCII,"tb_ascii_files",
            Constants.TB_ASCII_REPORT,"tb_ascii_report_files"
    );

